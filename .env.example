# ═══════════════════════════════════════════════════════
# Monitor Compras Chile — Variables de Entorno
# ═══════════════════════════════════════════════════════
# Copia este archivo como .env y rellena tus valores:
#   cp .env.example .env

# API Mercado Público (solicitar en https://api.mercadopublico.cl)
MERCADO_PUBLICO_TICKET=

# Telegram Bot (crear con @BotFather, obtener chat_id con obtener_chat_id.py)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# DeepSeek API (para el Cerebro Forense del dashboard)
DEEPSEEK_API_KEY=
